{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ProjetoMTA: iniciar tudo (1 clique)",
      "type": "shell",
      "command": ".\\iniciar-projeto.bat",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "ProjetoMTA: parar tudo",
      "type": "shell",
      "command": ".\\parar-projeto.bat",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Frontend: instalar dependências",
      "type": "shell",
      "command": "${workspaceFolder}/frontend/install-deps.bat",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: iniciar API",
      "type": "shell",
      "command": "${workspaceFolder}/backend/dev.bat",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "spring-boot",
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting ProjetoMtaApplication",
          "endsPattern": "Started ProjetoMtaApplication|Banco conectado"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "projeto-mta"
      }
    },
    {
      "label": "Frontend: iniciar Vite",
      "type": "shell",
      "command": "${workspaceFolder}/frontend/dev.bat",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Iniciando Vite",
          "endsPattern": "Local:|ready in"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "projeto-mta"
      }
    },
    {
      "label": "ProjetoMTA: subir back + front",
      "dependsOn": [
        "Backend: iniciar API",
        "Frontend: iniciar Vite"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
