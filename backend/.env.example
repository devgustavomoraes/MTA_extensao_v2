# Copie para backend/.env e preencha (NÃO commite o .env real)
# IntelliJ: Run Configuration → Environment variables ou plugin EnvFile

SPRING_PROFILES_ACTIVE=dev

# TiDB Cloud ou MySQL local
DB_HOST=localhost
DB_PORT=3306
DB_NAME=projeto_mta
DB_USERNAME=root
DB_PASSWORD=
DB_SSL_ENABLED=false
# DB_JDBC_URL=jdbc:mysql://host:4000/projeto_mta?useSSL=true&requireSSL=true&serverTimezone=UTC

# Pool (TiDB gratuito: manter baixo)
DB_POOL_MAX_SIZE=5
DB_POOL_MIN_IDLE=1

# Segurança
JWT_SECRET=substitua-por-string-aleatoria-com-pelo-menos-32-caracteres
JWT_EXPIRATION_MS=86400000

# CORS (URL do front Vite)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Admin inicial (criado no 1º boot se não existir)
SEED_ADMIN_EMAIL=admin@mta.local
SEED_ADMIN_PASSWORD=admin123

# Debug opcional
DB_SHOW_SQL=false
